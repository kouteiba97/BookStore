# Copy this file to .env and fill in your values
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
PORT=3000

# Which store the admin/single-store helpers resolve (optional; defaults to first store row)
STORE_SLUG=

# ── Cloudflare R2 (book-cover object storage) ─────────────────────────────
# Found in: Cloudflare dashboard → R2 → "Manage R2 API Tokens" (create an
# "Object Read & Write" token scoped to your bucket).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL that serves the bucket's objects (NO trailing slash). Either the
# bucket's r2.dev URL or a custom domain, e.g. https://covers.albayan.example
R2_PUBLIC_BASE_URL=
